rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true 
        || request.auth.token.email.matches('.*@motoryachtwhiskey\\.com')
        || request.auth.token.email.matches('.*@projects\\.vercel\\.app')
        || request.auth.token.email == 'ingjohs@gmail.com'
        || request.auth.token.email == 'ingjoh@gmail.com'
        || request.auth.token.email == 'ingemar.johnsson@gmail.com'
        || request.auth.token.email == 'ingemar.johnsson@tribes.co'
      );
    }

    // Global site settings rules
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site templates rules
    match /templates/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Media library assets rules
    match /assets/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Custom content type definitions rules
    match /content_types/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Raw content items rules
    match /content_items/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Messaging Engine Rules
    match /notification_templates/{document} {
      allow read, write: if request.auth != null;
    }

    match /notification_flows/{document} {
      allow read, write: if request.auth != null;
    }

    match /scheduled_notifications/{document} {
      allow read, write: if request.auth != null;
    }

    // Pages collection rules (houses pages, bookings, waivers, content items, locks, customers)
    match /pages/{document} {
      // Pages, adventures, locations, fleet specifications are publicly readable
      allow read: if true;

      // Clients can create new booking requests, passenger waivers, checkout locks, or customer profiles
      allow create: if request.resource.data.type == 'booking' 
                    || request.resource.data.type == 'waiver_signature'
                    || request.resource.data.type == 'lock'
                    || (request.resource.data.type == 'customer' 
                        && !('privateNotes' in request.resource.data));

      // Clients can update their own bookings to sign the digital waiver,
      // update checkout locks they own, or update their own customer profile.
      allow update: if isAdmin() 
                    || (resource.data.type == 'booking' 
                        && request.resource.data.waiverSigned == true 
                        && resource.data.waiverSigned == false)
                    || (resource.data.type == 'lock'
                        && request.resource.data.type == 'lock')
                    || (resource.data.type == 'customer'
                        && request.resource.data.type == 'customer'
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['privateNotes']));

      // Destructive deletion is reserved strictly for site administrators,
      // except for temporary checkout locks which clients can release/delete.
      allow delete: if isAdmin()
                    || (resource.data.type == 'lock');
    }
  }
}
