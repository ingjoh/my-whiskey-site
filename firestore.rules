rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Legacy/Platform-wide admin claim check
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true 
        || request.auth.token.email.matches('.*@motoryachtwhiskey\\.com')
        || request.auth.token.email.matches('.*@mywhiskey\\.com')
        || request.auth.token.email.matches('.*@projects\\.vercel\\.app')
        || request.auth.token.email == 'ingjohs@gmail.com'
        || request.auth.token.email == 'ingjoh@gmail.com'
        || request.auth.token.email == 'ingemar.johnsson@gmail.com'
        || request.auth.token.email == 'ingemar.johnsson@tribes.co'
      );
    }

    // Organization-aware role checks (ADR-004)
    function hasRole(orgId, role) {
      return request.auth != null && 
             request.auth.token.roles != null && 
             request.auth.token.roles[orgId] == role;
    }

    function isOrgMember(orgId) {
      return request.auth != null && 
             request.auth.token.roles != null && 
             request.auth.token.roles[orgId] != null;
    }

    function hasOperatorAccess(orgId) {
      return isAdmin() || hasRole(orgId, 'owner') || hasRole(orgId, 'admin') || hasRole(orgId, 'staff');
    }

    // Global site settings rules
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    // Site templates rules
    match /templates/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    // Media library assets rules
    match /assets/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    // Custom content type definitions rules
    match /content_types/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    // Raw content items rules
    match /content_items/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    // Messaging Engine Rules
    match /notification_templates/{document} {
      allow read, write: if request.auth != null;
    }

    match /notification_flows/{document} {
      allow read, write: if request.auth != null;
    }

    match /scheduled_notifications/{document} {
      allow read, write: if request.auth != null;
    }

    // Pages collection rules (houses pages, bookings, waivers, content items, locks, customers)
    match /pages/{document} {
      // Pages, adventures, locations, fleet specifications are publicly readable
      allow read: if true;

      // Clients can create new booking requests, passenger waivers, checkout locks, or customer profiles
      allow create: if isAdmin()
                    || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId))
                    || request.resource.data.type == 'booking' 
                    || request.resource.data.type == 'waiver_signature'
                    || request.resource.data.type == 'lock'
                    || (request.resource.data.type == 'customer' 
                        && !('privateNotes' in request.resource.data));

      // Clients can update their own bookings to sign the digital waiver,
      // update checkout locks they own, or update their own customer profile.
      allow update: if isAdmin() 
                    || (resource.data.tenantId != null && hasOperatorAccess(resource.data.tenantId))
                    || (resource.data.type == 'booking' 
                        && request.resource.data.waiverSigned == true 
                        && resource.data.waiverSigned == false)
                    || (resource.data.type == 'lock'
                        && request.resource.data.type == 'lock')
                    || (resource.data.type == 'customer'
                        && request.resource.data.type == 'customer'
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['privateNotes']));

      // Destructive deletion is reserved strictly for site administrators,
      // except for temporary checkout locks which clients can release/delete.
      allow delete: if isAdmin()
                    || (resource.data.tenantId != null && hasOperatorAccess(resource.data.tenantId))
                    || (resource.data.type == 'lock');
    }

    // Campaign planner drafts rules
    match /social_ad_drafts/{document} {
      allow read, write: if true;
    }

    // Calendar events rules
    match /calendar_events/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    // Blog posts rules
    match /blog_posts/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    // Identity schemas rules (new collections added in Epic 1)
    match /people/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    match /users/{document} {
      allow read: if request.auth != null && request.auth.uid == document;
      allow write: if request.auth != null && request.auth.uid == document;
    }

    match /organizations/{document} {
      allow read: if true;
      allow write: if isAdmin() || hasRole(document, 'owner') || hasRole(document, 'admin');
    }

    match /partnerships/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    match /roles/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /role_assignments/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.resource.data.scopeType == 'organization' && hasOperatorAccess(request.resource.data.scopeId));
    }

    match /capabilities/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    // Commercial schemas rules (new collections added in Epic 2)
    match /experiences/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /experiences/{experienceId}/itinerary_templates/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /listings/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    match /proposals/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    match /offers/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    match /bookings/{document} {
      allow get: if true; // Guests can retrieve single bookings by ID
      allow list: if request.auth != null; // Authenticated staff only can list bookings
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    // Trip galleries rules
    match /trip_galleries/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /resources/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    match /inventory_allocations/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    // Workspace Core Rules
    match /workspaces/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /workspace_configurations/{document} {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.tenantId != null && hasOperatorAccess(request.resource.data.tenantId));
    }

    match /workspace_memberships/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /workspace_bindings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin Notifications collection rules
    match /notifications/{document} {
      allow read, write: if isAdmin();
    }

    // Testimonials & Reviews collection rules
    match /testimonials/{document} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Crew Gratuity Payouts collection rules
    match /payouts/{document} {
      allow read, write: if isAdmin();
    }
  }
}
