rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an authenticated administrator
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Global site settings rules
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site templates rules
    match /templates/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Media library assets rules
    match /assets/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Custom content type definitions rules
    match /content_types/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Raw content items rules
    match /content_items/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Messaging Engine Rules
    match /notification_templates/{document} {
      allow read, write: if request.auth != null;
    }

    match /notification_flows/{document} {
      allow read, write: if request.auth != null;
    }

    match /scheduled_notifications/{document} {
      allow read, write: if request.auth != null;
    }

    // Pages collection rules (houses pages, bookings, waivers, content items, locks)
    match /pages/{document} {
      // Pages, adventures, locations, fleet specifications are publicly readable
      allow read: if true;

      // Clients can create new booking requests, passenger waivers, or checkout locks
      allow create: if request.resource.data.type == 'booking' 
                    || request.resource.data.type == 'waiver_signature'
                    || request.resource.data.type == 'lock';

      // Clients can update their own bookings to sign the digital waiver,
      // or update checkout locks they own or which are expired.
      allow update: if isAdmin() 
                    || (resource.data.type == 'booking' 
                        && request.resource.data.waiverSigned == true 
                        && resource.data.waiverSigned == false)
                    || (resource.data.type == 'lock'
                        && request.resource.data.type == 'lock');

      // Destructive deletion is reserved strictly for site administrators,
      // except for temporary checkout locks which clients can release/delete.
      allow delete: if isAdmin()
                    || (resource.data.type == 'lock');
    }
  }
}
